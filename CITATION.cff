    affiliation: "Facultad de Ingenieria Electrica, Universidad Michoacana de San Nicolas de Hidalgo"
    email: "1912574a@umich.mx"
version: "0.1.0"
date-released: "2026-07-02"
license: "MIT OR Apache-2.0"
keywords:
  - quaternion
  - non-commutative algebra
  - algebraic complexity
  - exact arithmetic
  - 3-SAT
  - hypergraph
repository-code: "https://github.com/mauramyrez/QIL-Research-Framework"
